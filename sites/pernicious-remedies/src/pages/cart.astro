---
import Base from '~/layouts/Base.astro';
---

<Base title="Cart">
  <section class="max-w-3xl mx-auto px-6 py-16 text-center">
    <h1>The Satchel</h1>
    <p class="mt-4 text-[color:var(--color-bone-dim)]">
      Your selections are stored in the small drawer at the top of the page. Click "Cart" to review.
    </p>
    <button id="open-cart" class="btn btn-primary mt-8">Open Satchel</button>
  </section>
</Base>

<script>
  document.getElementById('open-cart')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('cart:open'));
  });
</script>
