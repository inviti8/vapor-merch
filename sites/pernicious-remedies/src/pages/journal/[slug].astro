---
import Base from '~/layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('journal', (e) => !e.data.draft);
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<Base title={d.title} description={d.excerpt}>
  <article class="max-w-2xl mx-auto px-6 py-16 prose-gothic">
    <p class="eyebrow text-center">
      {d.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {d.author}
    </p>
    <h1 class="text-center mt-2">{d.title}</h1>
    <hr class="rule" />
    <Content />
    <hr class="rule" />
    <p class="text-center"><a href="/journal" class="eyebrow">← All entries</a></p>
  </article>
</Base>
