---
import Base from '~/layouts/Base.astro';
---

<Base title="Lost to Time">
  <section class="max-w-xl mx-auto px-6 py-24 text-center">
    <p class="eyebrow">404</p>
    <h1 class="mt-2">This Remedy Has Been Lost to Time</h1>
    <p class="mt-6 italic text-[color:var(--color-bone-dim)]">
      The page you sought has vanished, possibly into a lockbox, possibly into legend.
      We recommend returning to the cabinet and making a different selection.
    </p>
    <a href="/" class="btn mt-8">Return to the Parlour</a>
  </section>
</Base>
