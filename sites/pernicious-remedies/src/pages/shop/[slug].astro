---
import Base from '~/layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({ params: { slug: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const d = product.data;
---

<Base title={d.name} description={`${d.name} — ${d.vintageDate}. ${d.bottleSize}, ${d.closure}.`}>
  <article class="max-w-5xl mx-auto px-6 pt-16 pb-24 grid grid-cols-1 md:grid-cols-2 gap-12">
    <div>
      <img
        src={d.primaryImage}
        alt={d.name}
        class="w-full border border-[color:var(--color-gilt-aged)]/30"
      />
      {d.gallery.length > 0 && (
        <div class="grid grid-cols-4 gap-2 mt-4">
          {d.gallery.map((img) => (
            <img src={img} alt="" class="aspect-square object-cover border border-[color:var(--color-gilt-aged)]/20" />
          ))}
        </div>
      )}
    </div>

    <div>
      <p class="eyebrow">{d.vintageDate}</p>
      <h1 class="mt-2">{d.name}</h1>
      <p class="price mt-4">${d.priceUsd.toFixed(2)}</p>

      <div class="mt-6 prose-gothic">
        <Content />
      </div>

      <button
        id="add-to-cart"
        data-slug={product.id}
        data-name={d.name}
        data-price={d.priceUsd}
        data-stripe-price={d.stripePriceId}
        data-image={d.primaryImage}
        class="btn btn-primary mt-8 w-full md:w-auto"
        disabled={!d.inStock}
      >
        {d.inStock ? 'Add to the Satchel' : 'Currently Cursed — Unavailable'}
      </button>

      <dl class="mt-10 grid grid-cols-2 gap-4 text-sm border-t border-[color:var(--color-gilt-aged)]/30 pt-6">
        <div>
          <dt class="eyebrow">Bottle</dt>
          <dd class="mt-1">{d.bottleSize}</dd>
        </div>
        <div>
          <dt class="eyebrow">Closure</dt>
          <dd class="mt-1">{d.closure}</dd>
        </div>
        <div>
          <dt class="eyebrow">Contents</dt>
          <dd class="mt-1">{d.contents}</dd>
        </div>
        <div>
          <dt class="eyebrow">Ship Weight</dt>
          <dd class="mt-1">{d.weightOz} oz</dd>
        </div>
      </dl>

      <p class="mt-6 text-xs text-[color:var(--color-bone-dim)] italic">
        Decorative only. Not for consumption, medical use, or decision-making.
        <a href="/legal/not-for-consumption">Full disclosure</a>.
      </p>
    </div>
  </article>
</Base>

<script>
  import { addToCart } from '~/lib/cart';

  const btn = document.getElementById('add-to-cart');
  btn?.addEventListener('click', () => {
    const d = btn.dataset;
    addToCart({
      slug: d.slug!,
      name: d.name!,
      priceUsd: parseFloat(d.price!),
      stripePriceId: d.stripePrice!,
      image: d.image!,
    });
  });
</script>

<style is:global>
  .prose-gothic p { margin-bottom: 1rem; }
  .prose-gothic h2 { font-family: var(--font-display); font-size: 1.5rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .prose-gothic em { color: var(--color-gilt); font-style: italic; }
</style>
