---
interface Props {
  slug: string;
  name: string;
  vintageDate: string;
  priceUsd: number;
  primaryImage: string;
}

const { slug, name, vintageDate, priceUsd, primaryImage } = Astro.props;
---

<a href={`/shop/${slug}`} class="block group no-underline">
  <div class="aspect-[3/4] overflow-hidden border border-[color:var(--color-gilt-aged)]/30 bg-[color:var(--color-ink-soft)]">
    <img
      src={primaryImage}
      alt={name}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
  </div>
  <div class="mt-3 text-center">
    <p class="eyebrow">{vintageDate}</p>
    <h3 class="font-[family-name:var(--font-display)] text-xl mt-1 text-[color:var(--color-bone)] group-hover:text-[color:var(--color-gilt)] transition-colors">
      {name}
    </h3>
    <p class="price mt-1">${priceUsd.toFixed(2)}</p>
  </div>
</a>
