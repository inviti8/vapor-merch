---
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--color-gilt-aged)]/30 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-4 gap-8">
    <div class="md:col-span-2">
      <p class="font-[family-name:var(--font-display)] text-2xl italic text-[color:var(--color-bone)]">
        Remedies of dubious provenance.
      </p>
      <p class="mt-2 text-sm text-[color:var(--color-bone-dim)]">
        Hand-printed decorative bottles. Not for consumption.
        Est. whenever. Ships from somewhere on Earth.
      </p>
      <form id="newsletter" class="mt-6 flex gap-2 max-w-sm" action="/api/subscribe" method="POST">
        <input
          name="email"
          type="email"
          required
          placeholder="your@address"
          class="flex-1 bg-transparent border border-[color:var(--color-gilt-aged)] px-3 py-2 text-sm"
        />
        <button class="btn" type="submit">Subscribe</button>
      </form>
    </div>

    <div>
      <h4 class="eyebrow">Shop</h4>
      <ul class="mt-3 space-y-1 text-sm">
        <li><a href="/shop">All remedies</a></li>
        <li><a href="/collections/victorian-apothecary">Victorian Apothecary</a></li>
        <li><a href="/collections/modern-complaints">Modern Complaints</a></li>
        <li><a href="/wholesale">Wholesale</a></li>
      </ul>
    </div>

    <div>
      <h4 class="eyebrow">Legal</h4>
      <ul class="mt-3 space-y-1 text-sm">
        <li><a href="/legal/not-for-consumption">Not for consumption</a></li>
        <li><a href="/legal/terms">Terms</a></li>
        <li><a href="/legal/privacy">Privacy</a></li>
        <li><a href="/faq">Shipping & returns</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[color:var(--color-gilt-aged)]/20">
    <div class="max-w-6xl mx-auto px-6 py-4 text-xs text-[color:var(--color-bone-dim)] flex justify-between">
      <span>&copy; {year} Perni Cious Remedies. All curses reserved.</span>
      <span class="font-[family-name:var(--font-mono)] tracking-widest">Est. 1897 · Printed Today</span>
    </div>
  </div>
</footer>
